{
  "entities": {
    "User": {
      "title": "User",
      "description": "System users",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "branchName": { "type": "string" },
        "isDev": { "type": "boolean" }
      },
      "required": ["email", "name", "role", "branchName"]
    },
    "AppConfig": {
      "title": "Application Configuration",
      "description": "App-level configuration",
      "type": "object",
      "properties": {
        "logoUrl": { "type": "string" }
      }
    },
    "ShowroomMotorcycle": {
      "title": "Showroom Motorcycle",
      "description": "A motorcycle listed in the public showroom",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "brand": { "type": "string" },
        "price": { "type": "number" },
        "year": { "type": "number" },
        "mileage": { "type": "number" },
        "description": { "type": "string" },
        "photoBase64": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "name", "brand", "price", "year", "status"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "config/app": {
      "schema": "AppConfig",
      "description": "App configuration"
    },
    "showroom/{motorcycleId}": {
      "schema": "ShowroomMotorcycle",
      "description": "Public showroom motorcycles"
    }
  }
}
